{
  "expo": {
    "name": "The Living Olive",
    "slug": "the-living-olive",
    "scheme": "livingolive",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "updates": {
      "enabled": false
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.livingolive.app",
      "infoPlist": {
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "package": "com.livingolive.app",
      "adaptiveIcon": {
        "backgroundColor": "#F4EFE6",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": ["RECORD_AUDIO"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#5B7553"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#3E4A2F"
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow The Living Olive to record so you can capture sermon notes to be transcribed."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8d3faba2-00ef-4584-a32a-4cf63794178a"
      }
    },
    "owner": "iamnewtech"
  }
}
