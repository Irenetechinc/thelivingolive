# Copy this file to .env and fill in your values.
# EXPO_PUBLIC_* vars are embedded at build time and visible on-device —
# only put non-sensitive public keys here (Supabase anon key is safe via RLS).

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend API (server/) — proxies OpenAI and handles auth
EXPO_PUBLIC_API_URL=https://livingolive.adroomai.com

# Server-side only (never expose these in the mobile app)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# OPENAI_API_KEY=your-openai-api-key
