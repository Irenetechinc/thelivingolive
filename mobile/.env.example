# Copy to .env and fill in — Expo reads EXPO_PUBLIC_* vars at build time.
# These are safe to expose on-device: the anon key only grants access allowed by
# Supabase Row Level Security policies (see server/supabase/schema.sql).
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# URL of the backend server (server/) that proxies OpenAI calls.
# Use your Replit dev domain while developing, your Railway URL in production.
EXPO_PUBLIC_API_URL=https://your-repl-domain.replit.dev
